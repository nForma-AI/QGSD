{
  "version": 2,
  "description": "nf:solve benchmark fixture set",
  "fixtures": [
    {
      "id": "report-only-fast",
      "label": "Fast report-only sweep (skip proximity)",
      "args": ["--report-only", "--json", "--no-timeout", "--max-iterations=1", "--fast", "--skip-proximity"],
      "expect_convergence": false,
      "min_residual": null,
      "max_residual": null,
      "pass_condition": "exits_zero"
    },
    {
      "id": "report-only-full",
      "label": "Full report-only single-iteration sweep (fast mode)",
      "args": ["--report-only", "--json", "--no-timeout", "--max-iterations=1", "--fast"],
      "expect_convergence": false,
      "min_residual": null,
      "max_residual": null,
      "pass_condition": "exits_zero"
    },
    {
      "id": "skip-layers-r2f",
      "label": "Skip R->F layer, single iteration (fast mode)",
      "args": ["--report-only", "--json", "--no-timeout", "--max-iterations=1", "--fast", "--skip-layers=r_to_f"],
      "expect_convergence": false,
      "min_residual": null,
      "max_residual": null,
      "pass_condition": "exits_zero"
    },
    {
      "id": "focus-formal",
      "label": "Focus filter on 'formal model' topic (fast mode)",
      "args": ["--report-only", "--json", "--no-timeout", "--max-iterations=1", "--fast", "--focus=formal model"],
      "expect_convergence": false,
      "min_residual": null,
      "max_residual": null,
      "pass_condition": "exits_zero"
    },
    {
      "id": "zero-residual-check",
      "label": "Assert solver reports a numeric residual (not -1 error)",
      "args": ["--report-only", "--json", "--no-timeout", "--max-iterations=1", "--fast"],
      "expect_convergence": false,
      "min_residual": 0,
      "max_residual": null,
      "pass_condition": "exits_zero"
    },
    {
      "id": "invalid-focus-value",
      "label": "Invalid --focus value should still exit cleanly (fast mode)",
      "args": ["--report-only", "--json", "--no-timeout", "--max-iterations=1", "--fast", "--focus=__nonexistent_topic_xyz__"],
      "expect_convergence": false,
      "min_residual": null,
      "max_residual": null,
      "pass_condition": "exits_zero"
    },
    {
      "id": "layer-residual-regression",
      "label": "Key layer residuals within known bounds — catch regressions in solver output quality",
      "args": ["--report-only", "--json", "--no-timeout", "--max-iterations=1", "--fast"],
      "layer_assertions": {
        "r_to_f":        { "max": 5 },
        "f_to_t":        { "max": 5 },
        "c_to_f":        { "max": 3 },
        "trace_health":  { "max": 0 },
        "memory_health": { "max": 0 },
        "l1_to_l3":      { "max": 3 },
        "l3_to_tc":      { "max": 3 },
        "formal_lint":   { "max": 6 }
      },
      "expect_convergence": false,
      "min_residual": null,
      "max_residual": null,
      "pass_condition": "layer_residuals_in_range"
    }
  ],
  "autonomy_fixtures": [
    {
      "id": "seed-r2f-inject-uncovered-req",
      "label": "Seed r_to_f gap: inject Complete requirement with no formal model — nf-solve must detect it",
      "args": ["--json", "--no-timeout", "--max-iterations=1", "--fast"],
      "seed_mutation": {
        "type": "append_array_item",
        "file": ".planning/formal/requirements.json",
        "array_path": "requirements",
        "value": {
          "id": "BENCH-TEST-01",
          "text": "Benchmark fixture: requirement with no formal model coverage (ephemeral, restored post-run)",
          "category": "Test",
          "tier": "system",
          "phase": "unknown",
          "status": "Complete",
          "provenance": { "source_file": "benchmark-fixture", "milestone": "unknown" },
          "formal_models": []
        },
        "target_layer": "r_to_f"
      },
      "pass_condition": "residual_increased"
    },
    {
      "id": "seed-f2t-inject-property",
      "label": "Seed f_to_t gap: add Complete req + TLA+ annotation with no test — nf-solve must detect it",
      "args": ["--json", "--no-timeout", "--max-iterations=1", "--fast"],
      "target_layer": "f_to_t",
      "mutations": [
        {
          "type": "append_array_item",
          "file": ".planning/formal/requirements.json",
          "array_path": "requirements",
          "value": {
            "id": "BENCH-TEST-01",
            "text": "Benchmark fixture: formally modeled requirement with no test coverage (ephemeral)",
            "category": "Test",
            "tier": "system",
            "phase": "unknown",
            "status": "Complete",
            "provenance": { "source_file": "benchmark-fixture", "milestone": "unknown" },
            "formal_models": [".planning/formal/tla/NFOrchestration.tla"]
          }
        },
        {
          "type": "add_text_to_file",
          "file": ".planning/formal/tla/NFOrchestration.tla",
          "text": "\n\\* @requirement BENCH-TEST-01\nBenchmarkFakeProp == TRUE"
        }
      ],
      "pass_condition": "residual_increased"
    },
    {
      "id": "fix-f2t-stub-generation",
      "label": "f_to_t autoClose generates + implements stub for injected property — residual must decrease post-fix",
      "args": ["--json", "--no-timeout", "--max-iterations=1", "--fast"],
      "target_layer": "f_to_t",
      "mutations": [
        {
          "type": "append_array_item",
          "file": ".planning/formal/requirements.json",
          "array_path": "requirements",
          "value": {
            "id": "BENCH-TEST-01",
            "text": "Benchmark fixture: formally modeled requirement with no test coverage (ephemeral)",
            "category": "Test",
            "tier": "system",
            "phase": "unknown",
            "status": "Complete",
            "provenance": { "source_file": "benchmark-fixture", "milestone": "unknown" },
            "formal_models": [".planning/formal/tla/NFOrchestration.tla"]
          }
        },
        {
          "type": "add_text_to_file",
          "file": ".planning/formal/tla/NFOrchestration.tla",
          "text": "\n\\* @requirement BENCH-TEST-01\nBenchmarkFakeProp == TRUE"
        }
      ],
      "pass_condition": "residual_decreased"
    }
  ]
}
